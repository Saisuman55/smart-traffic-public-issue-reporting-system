# Firebase web app configuration
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIREBASE_API_KEY="your-web-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="optional-database-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_MEASUREMENT_ID=""

# Local or remote MongoDB database
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="Civic_Authority"

# NVIDIA API configuration
NVIDIA_API_KEY="your-nvidia-api-key"
NVIDIA_TEXT_MODEL="mistralai/mistral-medium-3-instruct"
NVIDIA_MULTIMODAL_MODEL="google/gemma-3n-e4b-it"

# Optional app URL for deployed environments
APP_URL="http://localhost:3000"
